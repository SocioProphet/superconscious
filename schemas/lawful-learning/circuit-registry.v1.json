{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/lawful-learning/circuit-registry.v1.json",
  "title": "LawfulLearningCircuitRegistryEntry",
  "description": "A circuit registry entry. Every circuit must have discovery evidence and ablation evidence. Allocation type must be declared.",
  "type": "object",
  "required": [
    "circuit_id",
    "circuit_name",
    "model_ref",
    "discovery_evidence_ref",
    "ablation_evidence_ref",
    "allocation_type",
    "allocation_evidence",
    "allocation_basis",
    "registry_status"
  ],
  "additionalProperties": false,
  "properties": {
    "circuit_id": {"type": "string", "pattern": "^circuit\\.[a-z0-9_.-]+$"},
    "circuit_name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "model_ref": {"type": "string"},
    "layer_range": {
      "type": "object",
      "required": ["from_layer", "to_layer"],
      "additionalProperties": false,
      "properties": {
        "from_layer": {"type": "integer", "minimum": 0},
        "to_layer": {"type": "integer", "minimum": 0}
      }
    },
    "discovery_evidence_ref": {"type": "string"},
    "ablation_evidence_ref": {"type": "string"},
    "allocation_type": {"type": "string", "enum": ["composition", "superposition", "mixed", "unknown"]},
    "allocation_evidence": {"type": "string", "minLength": 1},
    "allocation_basis": {"type": "string", "minLength": 1},
    "registry_status": {"type": "string", "enum": ["candidate", "admitted", "deprecated", "forbidden"]},
    "claim_refs": {"type": "array", "items": {"type": "string"}},
    "non_claims": {"type": "array", "items": {"type": "string"}},
    "replay_seal": {"type": "string"}
  }
}
