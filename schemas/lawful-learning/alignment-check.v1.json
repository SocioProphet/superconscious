{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/lawful-learning/alignment-check.v1.json",
  "title": "LawfulLearningAlignmentCheck",
  "description": "Alignment check record for a lawful-learning training run or composition. Checks structural alignment between declared claims, evidence, and governance invariants.",
  "type": "object",
  "required": [
    "check_id",
    "check_target_ref",
    "check_type",
    "check_result",
    "checked_invariants",
    "replay_seal"
  ],
  "additionalProperties": false,
  "properties": {
    "check_id": {"type": "string"},
    "check_target_ref": {"type": "string"},
    "check_type": {"type": "string", "enum": ["pre_training", "checkpoint", "post_training", "pre_publication", "composition_gate"]},
    "check_result": {"type": "string", "enum": ["pass", "fail", "partial", "deferred"]},
    "checked_invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["invariant_name", "result"],
        "additionalProperties": false,
        "properties": {
          "invariant_name": {
            "type": "string",
            "enum": [
              "adapter_dag_acyclic",
              "black_boxing_composes",
              "replay_seal_for_composed_trace",
              "may_wigner_monitor_declared",
              "control_data_plane_separation",
              "tail_audit_allocated",
              "emergent_discretization_logged",
              "composition_superposition_declared",
              "anti_satisficing_continuation",
              "epistemic_non_collapse"
            ]
          },
          "result": {"type": "string", "enum": ["pass", "fail", "not_applicable", "deferred"]},
          "failure_detail": {"type": "string"},
          "checker_version": {"type": "string"}
        },
        "allOf": [
          {"if": {"properties": {"result": {"const": "fail"}}}, "then": {"required": ["failure_detail"], "properties": {"failure_detail": {"minLength": 1}}}}
        ]
      }
    },
    "replay_seal": {"type": "string"},
    "timestamp": {"type": "string", "format": "date-time"},
    "checker_ref": {"type": "string"},
    "non_claims": {"type": "array", "items": {"type": "string"}}
  }
}
