{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.ai/superconscious/m2/implementability-curve.v1.json",
  "title": "M2 Implementability Curve Certificate Fragment",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "certificate_kind", "generated_at", "parent_fragment_id", "feature_ref", "alpha_behavioral_ref", "manifold_baseline_ref", "intervention_curves", "pattern_classification", "execution_status", "signing_authority", "counterfactuals_addressable", "ledger_entry"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "certificate_kind": { "const": "m2-implementability-curve" },
    "generated_at": { "type": "string", "format": "date-time" },
    "parent_fragment_id": { "type": "string" },
    "feature_ref": { "type": "object", "additionalProperties": false, "required": ["m1b_witness_card_id", "m1c_causal_triad_id", "m1d_off_target_audit_id"], "properties": { "m1b_witness_card_id": { "type": "string" }, "m1c_causal_triad_id": { "type": "string" }, "m1d_off_target_audit_id": { "type": "string" } } },
    "alpha_behavioral_ref": { "type": "object", "additionalProperties": false, "required": ["value", "source_certificate_id"], "properties": { "value": { "type": "number" }, "source_certificate_id": { "type": "string" } } },
    "manifold_baseline_ref": { "$ref": "#/$defs/fragmentRef" },
    "intervention_curves": { "type": "object", "additionalProperties": false, "required": ["studied_feature_steering", "no_intervention", "random_direction", "alternative_feature_steering", "teleportation"], "properties": { "studied_feature_steering": { "$ref": "#/$defs/curveData" }, "no_intervention": { "$ref": "#/$defs/curveData" }, "random_direction": { "$ref": "#/$defs/curveData" }, "alternative_feature_steering": { "$ref": "#/$defs/curveData" }, "teleportation": { "$ref": "#/$defs/curveData" } } },
    "pattern_classification": { "type": "object", "additionalProperties": false, "required": ["pattern", "rationale", "alpha_behavioral_in_curve", "distance_at_alpha_behavioral", "decision_thresholds_used"], "properties": { "pattern": { "enum": ["A_in_envelope", "B_boundary_crossing", "C_out_of_distribution", "indeterminate"] }, "rationale": { "type": "string" }, "alpha_behavioral_in_curve": { "type": "number" }, "distance_at_alpha_behavioral": { "type": "object", "additionalProperties": { "type": "object", "additionalProperties": false, "required": ["metric_id", "distance", "quantile_position"], "properties": { "metric_id": { "type": "string" }, "distance": { "type": "number" }, "quantile_position": { "type": "string" } } } }, "decision_thresholds_used": { "type": "object", "additionalProperties": false, "required": ["in_envelope_threshold_quantile", "ood_threshold_quantile"], "properties": { "in_envelope_threshold_quantile": { "enum": ["q50", "q90", "q95", "q99"] }, "ood_threshold_quantile": { "enum": ["q95", "q99", "q999"] } } } } },
    "execution_status": { "$ref": "#/$defs/executionStatus" },
    "signing_authority": { "$ref": "#/$defs/signingAuthority" },
    "counterfactuals_addressable": { "$ref": "#/$defs/counterfactualsAddressable" },
    "ledger_entry": { "$ref": "#/$defs/ledgerEntry" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "executionStatus": { "enum": ["doctrine_only", "synthetic_fixture", "runtime_partial", "runtime_executed", "failed"] },
    "fragmentRef": { "type": "object", "additionalProperties": false, "required": ["fragment_id", "fragment_sha256"], "properties": { "fragment_id": { "type": "string" }, "fragment_sha256": { "$ref": "#/$defs/sha256" } } },
    "curveData": { "type": "object", "additionalProperties": false, "required": ["alpha_grid", "per_alpha_distance"], "properties": { "alpha_grid": { "type": "array", "items": { "type": "number" } }, "per_alpha_distance": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["alpha", "distances_by_metric"], "properties": { "alpha": { "type": "number" }, "distances_by_metric": { "type": "object", "additionalProperties": { "type": "number" } } } } } } },
    "signingAuthority": { "type": "object", "additionalProperties": false, "required": ["authority_id", "authority_kind", "signed_at", "signing_method", "delegation_chain"], "properties": { "authority_id": { "type": "string" }, "authority_kind": { "enum": ["individual", "automated_pipeline", "role", "delegated", "external_auditor"] }, "signed_at": { "type": "string", "format": "date-time" }, "signing_method": { "enum": ["sha256_content_hash", "gpg_signature", "sigstore", "x509", "internal_hmac"] }, "delegation_chain": { "type": "array", "items": { "type": "string" } } } },
    "counterfactualsAddressable": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["question_id", "question", "evidence_path", "answer_form", "answered_by_synthetic_fixture"], "properties": { "question_id": { "type": "string", "pattern": "^cf-[a-z0-9-]+$" }, "question": { "type": "string" }, "evidence_path": { "type": "string" }, "answer_form": { "enum": ["boolean", "hash_match", "numerical_range", "categorical", "structured"] }, "answered_by_synthetic_fixture": { "type": "boolean" } } } },
    "ledgerEntry": { "type": "object", "additionalProperties": false, "required": ["fragment_id", "fragment_sha256", "content_sha256_canonical", "parent_fragment_id", "child_fragment_ids", "controller_spec_id", "sealed_at", "sealed_by", "supersedes"], "properties": { "fragment_id": { "type": "string" }, "fragment_sha256": { "$ref": "#/$defs/sha256" }, "content_sha256_canonical": { "$ref": "#/$defs/sha256" }, "parent_fragment_id": { "type": ["string", "null"] }, "child_fragment_ids": { "type": "array", "items": { "type": "string" } }, "controller_spec_id": { "type": "string" }, "sealed_at": { "type": "string", "format": "date-time" }, "sealed_by": { "type": "string" }, "supersedes": { "type": ["string", "null"] } } }
  }
}
