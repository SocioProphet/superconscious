{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superconscious.dev/schemas/m0/training-provenance.v1.json",
  "title": "M0 Training Provenance Certificate",
  "description": "Upstream provenance for an artifact. M0 sits upstream of M1A source-lock and records what is known about how the artifact came to exist. It commits to typed terminals and a temporal constraint; it does not prove SGD ran correctly.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "certificate_kind",
    "generated_at",
    "artifact_identity",
    "commitments",
    "temporal_constraints",
    "provenance_completeness",
    "execution_status",
    "signing_authority",
    "counterfactuals_addressable",
    "non_claims",
    "ledger_entry"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "certificate_kind": {
      "const": "m0-training-provenance"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_kind",
        "content_sha256"
      ],
      "properties": {
        "artifact_id": {
          "type": "string"
        },
        "artifact_kind": {
          "type": "string",
          "enum": [
            "base_model",
            "fine_tuned_model",
            "sae",
            "transcoder",
            "dataset",
            "tokenizer",
            "calibration_map"
          ]
        },
        "content_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "repo_path": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "commitments": {
      "type": "object",
      "additionalProperties": false,
      "description": "Eight commitments to typed terminals. Each commitment is either populated or explicitly marked unavailable.",
      "required": [
        "dataset",
        "code",
        "config",
        "seed",
        "base_model",
        "checkpoint",
        "eval_spec",
        "compute_environment"
      ],
      "properties": {
        "dataset": {
          "$ref": "#/$defs/commitment"
        },
        "code": {
          "$ref": "#/$defs/commitment"
        },
        "config": {
          "$ref": "#/$defs/commitment"
        },
        "seed": {
          "$ref": "#/$defs/commitment"
        },
        "base_model": {
          "$ref": "#/$defs/commitment"
        },
        "checkpoint": {
          "$ref": "#/$defs/commitment"
        },
        "eval_spec": {
          "$ref": "#/$defs/commitment"
        },
        "compute_environment": {
          "$ref": "#/$defs/commitment"
        }
      }
    },
    "temporal_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_commitment_at",
        "eval_spec_commitment_at",
        "model_precedes_eval_spec"
      ],
      "properties": {
        "model_commitment_at": {
          "oneOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        },
        "eval_spec_commitment_at": {
          "oneOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        },
        "model_precedes_eval_spec": {
          "type": "boolean"
        },
        "constraint_satisfied_evidence_path": {
          "type": "string"
        }
      }
    },
    "provenance_completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "interpretation",
        "external_artifact_flag"
      ],
      "properties": {
        "index": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "interpretation": {
          "type": "string",
          "enum": [
            "fully_provenance_certified",
            "partial_provenance",
            "minimal_provenance",
            "no_provenance_external_artifact"
          ]
        },
        "external_artifact_flag": {
          "type": "boolean"
        }
      }
    },
    "execution_status": {
      "type": "string",
      "enum": [
        "doctrine_only",
        "synthetic_fixture",
        "runtime_executed",
        "runtime_partial"
      ]
    },
    "signing_authority": {
      "$ref": "#/$defs/signing_authority"
    },
    "counterfactuals_addressable": {
      "$ref": "#/$defs/counterfactuals_addressable"
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "contains": {
        "const": "Does not prove SGD ran correctly."
      },
      "items": {
        "type": "string"
      }
    },
    "ledger_entry": {
      "$ref": "#/$defs/ledger_entry"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "signing_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_id",
        "authority_kind",
        "signed_at",
        "signing_method"
      ],
      "properties": {
        "authority_id": {
          "type": "string"
        },
        "authority_kind": {
          "type": "string",
          "enum": [
            "individual",
            "automated_pipeline",
            "role",
            "delegated",
            "external_auditor"
          ]
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        },
        "signing_method": {
          "type": "string",
          "enum": [
            "sha256_content_hash",
            "gpg_signature",
            "sigstore",
            "x509",
            "internal_hmac"
          ]
        },
        "delegation_chain": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "counterfactuals_addressable": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "question_id",
          "question",
          "evidence_path",
          "answer_form",
          "answered_by_synthetic_fixture"
        ],
        "properties": {
          "question_id": {
            "type": "string",
            "pattern": "^cf-[a-z0-9-]+$"
          },
          "question": {
            "type": "string"
          },
          "evidence_path": {
            "type": "string"
          },
          "answer_form": {
            "type": "string",
            "enum": [
              "boolean",
              "hash_match",
              "numerical_range",
              "categorical",
              "structured"
            ]
          },
          "answered_by_synthetic_fixture": {
            "type": "boolean"
          }
        }
      }
    },
    "ledger_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ledger_id",
        "supersedes",
        "promotion_status"
      ],
      "properties": {
        "ledger_id": {
          "type": "string"
        },
        "supersedes": {
          "type": [
            "string",
            "null"
          ]
        },
        "promotion_status": {
          "type": "string"
        }
      }
    },
    "commitment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value_or_reason"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "available",
            "publicly_unavailable",
            "withheld_for_privacy",
            "not_applicable",
            "unknown"
          ]
        },
        "value_or_reason": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "identifier": {
                  "type": "string"
                },
                "content_sha256": {
                  "oneOf": [
                    {
                      "$ref": "#/$defs/sha256"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "version": {
                  "type": "string"
                },
                "uri": {
                  "type": "string"
                }
              },
              "required": [
                "identifier"
              ]
            },
            {
              "type": "string"
            }
          ]
        },
        "committed_at": {
          "oneOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "provenance_completeness": {
            "properties": {
              "external_artifact_flag": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "non_claims": {
            "contains": {
              "pattern": "External artifact|external artifact|not published|not disclosed|unavailable|not public"
            }
          }
        }
      }
    }
  ]
}
