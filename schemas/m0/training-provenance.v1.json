{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superconscious.dev/schemas/m0/training-provenance.v1.json",
  "title": "M0 Training Provenance Certificate",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "certificate_kind", "generated_at", "artifact_identity", "commitments", "temporal_constraints", "provenance_completeness", "execution_status", "signing_authority", "counterfactuals_addressable", "non_claims", "ledger_entry"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "certificate_kind": {"const": "m0-training-provenance"},
    "generated_at": {"type": "string", "format": "date-time"},
    "artifact_identity": {
      "type": "object",
      "required": ["artifact_id", "artifact_kind", "content_sha256"],
      "properties": {
        "artifact_id": {"type": "string"},
        "artifact_kind": {"type": "string", "enum": ["base_model", "fine_tuned_model", "sae", "transcoder", "dataset", "tokenizer", "calibration_map"]},
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "repo_path": {"type": ["string", "null"]}
      }
    },
    "commitments": {
      "type": "object",
      "required": ["dataset", "code", "config", "seed", "base_model", "checkpoint", "eval_spec", "compute_environment"],
      "properties": {
        "dataset": {"$ref": "#/$defs/commitment"},
        "code": {"$ref": "#/$defs/commitment"},
        "config": {"$ref": "#/$defs/commitment"},
        "seed": {"$ref": "#/$defs/commitment"},
        "base_model": {"$ref": "#/$defs/commitment"},
        "checkpoint": {"$ref": "#/$defs/commitment"},
        "eval_spec": {"$ref": "#/$defs/commitment"},
        "compute_environment": {"$ref": "#/$defs/commitment"}
      }
    },
    "temporal_constraints": {
      "type": "object",
      "required": ["model_commitment_at", "eval_spec_commitment_at", "model_precedes_eval_spec"],
      "properties": {
        "model_commitment_at": {"type": ["string", "null"], "format": "date-time"},
        "eval_spec_commitment_at": {"type": ["string", "null"], "format": "date-time"},
        "model_precedes_eval_spec": {"type": "boolean"},
        "constraint_satisfied_evidence_path": {"type": "string"}
      }
    },
    "provenance_completeness": {
      "type": "object",
      "required": ["index", "interpretation", "external_artifact_flag"],
      "properties": {
        "index": {"type": "number", "minimum": 0, "maximum": 1},
        "interpretation": {"type": "string", "enum": ["fully_provenance_certified", "partial_provenance", "minimal_provenance", "no_provenance_external_artifact"]},
        "external_artifact_flag": {"type": "boolean"}
      }
    },
    "execution_status": {"type": "string"},
    "signing_authority": {"type": "object"},
    "counterfactuals_addressable": {"type": "array", "minItems": 1},
    "non_claims": {"type": "array", "minItems": 1, "items": {"type": "string"}, "contains": {"const": "Does not prove SGD ran correctly."}},
    "ledger_entry": {"type": "object"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "commitment": {
      "type": "object",
      "required": ["status", "value_or_reason"],
      "properties": {
        "status": {"type": "string", "enum": ["available", "publicly_unavailable", "withheld_for_privacy", "not_applicable", "unknown"]},
        "value_or_reason": {"oneOf": [{"type": "object"}, {"type": "string"}]},
        "committed_at": {"type": ["string", "null"], "format": "date-time"}
      }
    }
  }
}
