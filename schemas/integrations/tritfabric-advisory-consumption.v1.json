{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.ai/superconscious/schemas/integrations/tritfabric-advisory-consumption.v1.json",
  "title": "TritFabric Advisory Consumption Boundary",
  "type": "object",
  "required": [
    "schema_version",
    "integration_id",
    "mode",
    "authority_boundaries",
    "allowed_uses",
    "prohibited_authority",
    "claim_boundary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "superconscious.tritfabric-advisory-consumption/v1"},
    "integration_id": {"type": "string", "minLength": 1},
    "mode": {"const": "coordinator-advisory-only"},
    "authority_boundaries": {
      "type": "object",
      "required": ["superconscious", "tritfabric", "ontogenesis", "sociosphere", "prophet_platform"],
      "additionalProperties": false,
      "properties": {
        "superconscious": {"const": "advisory-coordinator"},
        "tritfabric": {"const": "implementation-contract-owner"},
        "ontogenesis": {"const": "vocabulary-shacl-owner"},
        "sociosphere": {"const": "estate-registration-owner"},
        "prophet_platform": {"const": "product-consumer"}
      }
    },
    "allowed_uses": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "prohibited_authority": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "enum": [
        "model-promotion",
        "community-eligibility-final-authority",
        "adapter-validation",
        "economic-credit-creation",
        "serve-deployment",
        "contract-override",
        "execution-authorization"
      ]}
    },
    "claim_boundary": {"type": "string", "minLength": 1}
  }
}
