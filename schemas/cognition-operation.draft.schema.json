{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:socioprophet:superconscious:schema:cognition-operation:draft",
  "title": "CognitionRun Draft Schema",
  "description": "Local draft schema for Superconscious governed cognition loop artifacts. Canonical ownership belongs in SourceOS-Linux/sourceos-spec.",
  "type": "object",
  "required": [
    "kind",
    "specVersion",
    "runId",
    "status",
    "task",
    "agent",
    "workspace",
    "safeTrace",
    "adapterTrace",
    "cognitionPosture",
    "directMutation",
    "events",
    "artifactRefs"
  ],
  "properties": {
    "kind": { "const": "CognitionRun" },
    "specVersion": { "type": "string" },
    "runId": { "type": "string", "pattern": "^urn:srcos:cognition-run:" },
    "status": { "enum": ["created", "running", "completed", "failed", "blocked"] },
    "task": { "type": "object" },
    "agent": { "type": "object" },
    "workspace": { "type": "object" },
    "safeTrace": {
      "type": "object",
      "required": ["mode", "rawChainOfThought", "eventCount"],
      "properties": {
        "mode": { "const": "operational-trace-only" },
        "rawChainOfThought": { "const": "not-collected" },
        "eventCount": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "adapterTrace": { "type": "object" },
    "cognitionPosture": {
      "const": "read-reflect-propose",
      "description": "The cognition loop must always be read/reflect/propose. It never directly mutates workspace state."
    },
    "directMutation": {
      "const": false,
      "description": "Must always be false. Any remediation routes through AgentPlane / OperationContract."
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["eventId", "runId", "type", "occurredAt", "summary", "traceLevel", "trustLevel"],
        "properties": {
          "eventId": { "type": "string", "pattern": "^urn:srcos:cognition-event:" },
          "runId": { "type": "string", "pattern": "^urn:srcos:cognition-run:" },
          "type": {
            "enum": [
              "cognition.observe.operation",
              "cognition.reflect.run",
              "cognition.remediation.propose",
              "cognition.learning_loop.record",
              "cognition.risk_signal.emit",
              "cognition.policy_review.request"
            ]
          },
          "occurredAt": { "type": "string" },
          "summary": { "type": "string", "minLength": 1 },
          "traceLevel": {
            "enum": ["public-safe", "workspace-safe", "operator-private", "restricted", "denied"]
          },
          "trustLevel": {
            "enum": [
              "trusted-control-input",
              "trusted-workspace-source",
              "semi-trusted-project-source",
              "untrusted-observation",
              "restricted-material"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "artifactRefs": {
      "type": "object",
      "required": ["events", "reflection", "remediationProposal", "riskSignal", "policyReviewRequest", "learningLoopRecord", "benchmarkResult"],
      "properties": {
        "events": { "const": "cognition-events.jsonl" },
        "reflection": { "const": "cognition-reflection.json" },
        "remediationProposal": { "const": "cognition-remediation-proposal.json" },
        "riskSignal": { "const": "cognition-risk-signal.json" },
        "policyReviewRequest": { "const": "cognition-policy-review-request.json" },
        "learningLoopRecord": { "const": "cognition-learning-loop-record.json" },
        "benchmarkResult": { "const": "cognition-benchmark-result.json" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
