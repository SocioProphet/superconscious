{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://socioprophet.dev/schemas/pneumachinalis/mesobeat-intent.v1.1.json",
  "title":"Pneumachinalis Mesobeat Intent Bundle v1.1",
  "type":"object",
  "additionalProperties":true,
  "required":["schema_version","intent_kind","intent_id","ts_mesobeat","stream_id","scope","filters","policy_overlays","active_schema_refs","active_policy_refs","authority_layer","cadence_classification"],
  "properties":{
    "schema_version":{"const":"1.1.0"},
    "intent_kind":{"const":"pneumachinalis-mesobeat-intent"},
    "intent_id":{"type":"string"},
    "ts_mesobeat":{"type":"string","format":"date-time"},
    "stream_id":{"type":"string"},
    "scope":{"type":"object","required":["scope_kind","scope_value","topology_profile"],"properties":{"scope_kind":{"enum":["single_artifact","artifact_family","domain","cross_domain_query","stream_replay","audit_window"]},"scope_value":{"type":"object"},"topology_profile":{"enum":["solo-local","active-multi-agent-room","multi-room-workroom","enterprise-bridge","offline-fog"]}}},
    "filters":{"type":"object"},
    "policy_overlays":{"type":"array","items":{"type":"object"}},
    "active_schema_refs":{"type":"array","minItems":1,"items":{"type":"object","required":["schema_id","schema_content_sha256"],"properties":{"schema_id":{"type":"string"},"schema_content_sha256":{"$ref":"#/$defs/sha256"}}}},
    "active_policy_refs":{"type":"array","minItems":1,"items":{"type":"object","required":["policy_id","policy_content_sha256","policy_epoch"],"properties":{"policy_id":{"type":"string"},"policy_content_sha256":{"$ref":"#/$defs/sha256"},"policy_epoch":{"type":"integer","minimum":0}}}},
    "default_braid_coordinate":{"type":"object"},
    "default_state_coordinate":{"type":"object"},
    "cursor_window_policy":{"type":"object"},
    "authority_layer":{"enum":["institutional_truth","grounded_schema","commonsense_prior"]},
    "cadence_classification":{"const":"mesobeat"},
    "signing_authority":{"type":"object"},
    "non_claims":{"type":"array","items":{"type":"string"}}
  },
  "$defs":{"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"}}
}
