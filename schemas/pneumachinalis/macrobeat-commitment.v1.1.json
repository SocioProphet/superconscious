{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://socioprophet.dev/schemas/pneumachinalis/macrobeat-commitment.v1.1.json",
  "title":"Pneumachinalis Macrobeat Commitment Manifest v1.1",
  "type":"object",
  "additionalProperties":true,
  "required":["schema_version","commitment_kind","commitment_id","ts_macrobeat","manifest_payload","supersedes","authority_layer","cadence_classification","signing_authority_chain"],
  "properties":{
    "schema_version":{"const":"1.1.0"},
    "commitment_kind":{"enum":["schema_manifest","policy_manifest","authority_chain_manifest","vocabulary_version","decay_kernel_params","role_mapping_table","stream_commit_receipt","stake_resolution_receipt","redaction_tombstone"]},
    "commitment_id":{"type":"string"},
    "ts_macrobeat":{"type":"string","format":"date-time"},
    "manifest_payload":{"oneOf":[{"type":"object","required":["payload_kind"]}]},
    "supersedes":{"type":["string","null"]},
    "successor_pointer":{"type":["string","null"]},
    "authority_layer":{"enum":["institutional_truth","grounded_schema","commonsense_prior"]},
    "cadence_classification":{"const":"macrobeat"},
    "signing_authority_chain":{"type":"array","minItems":1,"items":{"type":"object","required":["authority_id","authority_kind","signed_at","signing_method"],"properties":{"authority_id":{"type":"string"},"authority_kind":{"enum":["role","individual","service_account","quorum"]},"signed_at":{"type":"string","format":"date-time"},"signing_method":{"enum":["sha256_content_hash","blake3_content_hash","ed25519_signature","multi_party_signature"]},"signature_value":{"type":"string"}}}},
    "authority_concentration_index":{"type":"object"},
    "non_claims":{"type":"array","items":{"type":"string"}}
  }
}
