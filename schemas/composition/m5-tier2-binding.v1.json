{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.org/schemas/composition/m5-tier2-binding.v1.json",
  "title": "M5 Public Note — Tier 2 Invariant Binding",
  "description": "Doctrine-only schema binding M5 public-note publication compositions to ProCybernetica Tier 2 invariant declared modes. Opaque hashes only; no runtime publication gate, peer-review substitution, or analysis execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "composition_id",
    "composition_kind",
    "binding_doctrine_version",
    "upstream_certificate_refs",
    "publication_surface_ref",
    "bound_modes",
    "non_claims"
  ],
  "properties": {
    "composition_id": {"const": "superconscious.m5.public_note"},
    "composition_kind": {"const": "publication_composition"},
    "binding_doctrine_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$",
      "description": "Doctrine version under which this binding is declared. Pins the binding to a specific Tier 2 invariant binding revision."
    },
    "upstream_certificate_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref_kind", "opaque_hash"],
        "properties": {
          "ref_kind": {
            "type": "string",
            "enum": ["m1_certificate", "m2_certificate", "m3_certificate", "robustness_certificate", "implementability_certificate"]
          },
          "opaque_hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$",
            "description": "Opaque content-addressed reference. This binding schema does not resolve the hash at validation time."
          }
        }
      }
    },
    "publication_surface_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_kind", "opaque_hash"],
      "properties": {
        "ref_kind": {"const": "public_note_artifact"},
        "opaque_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$",
          "description": "Opaque content-addressed reference for the public-note artifact. This binding schema does not resolve the hash at validation time."
        }
      }
    },
    "bound_modes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_integration",
        "authority_scope_analysis",
        "non_claim_analysis",
        "monitor_independence_analysis",
        "evidence_freshness_analysis"
      ],
      "properties": {
        "receipt_integration": {"const": "hash_bound_reference"},
        "authority_scope_analysis": {"const": "declared_scope_lattice_v1"},
        "non_claim_analysis": {"const": "explicit_propagate_or_resolve_v1"},
        "monitor_independence_analysis": {"const": "declared_monitor_independence_v1"},
        "evidence_freshness_analysis": {"const": "declared_evidence_freshness_v1"}
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true,
      "items": {
        "enum": [
          "no_runtime_receipt_lookup",
          "no_runtime_non_claim_verification",
          "no_runtime_monitor_attestation",
          "no_timestamp_authenticity",
          "opaque_hashes_not_resolved",
          "no_runtime_publication_gate",
          "no_peer_review_substitution"
        ]
      }
    }
  }
}
