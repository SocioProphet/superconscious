{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.org/schemas/composition/m1-tier2-binding.v1.json",
  "title": "M1 Composite — Tier 2 Invariant Binding",
  "description": "Doctrine-only schema binding M1 composite certificate fragments to ProCybernetica Tier 2 invariant declared modes. Opaque hashes only; no runtime verification or analysis execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "composition_id",
    "composition_kind",
    "binding_doctrine_version",
    "constituent_refs",
    "bound_modes",
    "non_claims"
  ],
  "properties": {
    "composition_id": {
      "const": "superconscious.m1.composite"
    },
    "composition_kind": {
      "const": "certificate_fragment_composition"
    },
    "binding_doctrine_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$",
      "description": "Doctrine version under which this binding is declared. Pins the binding to a specific Tier 2 invariant binding revision."
    },
    "constituent_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref_kind", "opaque_hash"],
        "properties": {
          "ref_kind": {
            "const": "certificate_fragment"
          },
          "opaque_hash": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$",
            "description": "Opaque content-addressed reference. This binding schema does not resolve the hash at validation time."
          }
        }
      }
    },
    "bound_modes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_integration",
        "authority_scope_analysis",
        "non_claim_analysis",
        "monitor_independence_analysis",
        "evidence_freshness_analysis"
      ],
      "properties": {
        "receipt_integration": {"const": "hash_bound_reference"},
        "authority_scope_analysis": {"const": "declared_scope_lattice_v1"},
        "non_claim_analysis": {"const": "explicit_propagate_or_resolve_v1"},
        "monitor_independence_analysis": {"const": "declared_monitor_independence_v1"},
        "evidence_freshness_analysis": {"const": "declared_evidence_freshness_v1"}
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "enum": [
          "no_runtime_receipt_lookup",
          "no_runtime_non_claim_verification",
          "no_runtime_monitor_attestation",
          "no_timestamp_authenticity",
          "opaque_hashes_not_resolved"
        ]
      }
    }
  }
}
