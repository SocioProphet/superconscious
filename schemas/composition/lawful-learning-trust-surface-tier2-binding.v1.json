{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.org/schemas/composition/lawful-learning-trust-surface-tier2-binding.v1.json",
  "title": "Lawful-Learning Trust Surface — Tier 2 Invariant Binding",
  "description": "Doctrine-only schema binding lawful-learning trust-surface compositions to ProCybernetica Tier 2 invariant declared modes. Opaque hashes only; no runtime circuit discovery, ablation verification, tag promotion, substrate verification, or frontier-claim promotion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "composition_id",
    "composition_kind",
    "binding_doctrine_version",
    "substrate_component_refs",
    "structure_component_refs",
    "mixture_slot_refs",
    "adapter_dag_ref",
    "circuit_registry_ref",
    "claim_ledger_ref",
    "bound_modes",
    "non_claims"
  ],
  "properties": {
    "composition_id": {"const": "superconscious.lawful_learning.trust_surface"},
    "composition_kind": {"const": "lawful_learning_trust_surface_declaration"},
    "binding_doctrine_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$",
      "description": "Doctrine version under which this binding is declared. Pins the binding to a specific Tier 2 invariant binding revision."
    },
    "substrate_component_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/component_ref"}},
    "structure_component_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/component_ref"}},
    "mixture_slot_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/component_ref"}},
    "adapter_dag_ref": {"$ref": "#/$defs/component_ref"},
    "circuit_registry_ref": {"$ref": "#/$defs/component_ref"},
    "claim_ledger_ref": {"$ref": "#/$defs/component_ref"},
    "bound_modes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_integration",
        "authority_scope_analysis",
        "non_claim_analysis",
        "monitor_independence_analysis",
        "evidence_freshness_analysis"
      ],
      "properties": {
        "receipt_integration": {"const": "hash_bound_reference"},
        "authority_scope_analysis": {"const": "declared_scope_lattice_v1"},
        "non_claim_analysis": {"const": "explicit_propagate_or_resolve_v1"},
        "monitor_independence_analysis": {"const": "declared_monitor_independence_v1"},
        "evidence_freshness_analysis": {"const": "declared_evidence_freshness_v1"}
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "enum": [
          "no_runtime_receipt_lookup",
          "no_runtime_non_claim_verification",
          "no_runtime_monitor_attestation",
          "no_timestamp_authenticity",
          "opaque_hashes_not_resolved",
          "no_runtime_circuit_discovery",
          "no_runtime_ablation_verification",
          "no_tag_promotion_at_composition",
          "no_substrate_verification",
          "no_frontier_claim_promotion"
        ]
      }
    }
  },
  "$defs": {
    "component_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_kind", "claim_id", "opaque_hash"],
      "properties": {
        "ref_kind": {
          "type": "string",
          "enum": [
            "substrate_component",
            "structure_component",
            "mixture_slot",
            "adapter_dag",
            "circuit_registry",
            "claim_ledger"
          ]
        },
        "claim_id": {
          "type": "string",
          "description": "Claim or ledger identifier from the lawful-learning capture corpus. The binding schema does not dereference or promote this claim."
        },
        "opaque_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$",
          "description": "Opaque content-addressed reference. This binding schema does not resolve the hash at validation time."
        }
      }
    }
  }
}
