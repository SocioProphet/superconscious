{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:socioprophet:superconscious:schema:agentplane-reasoning-evidence:draft",
  "title": "AgentPlaneReasoningEvidence Draft Schema",
  "description": "Local draft schema for AgentPlane-compatible reasoning evidence. Canonical ownership belongs in SourceOS-Linux/sourceos-spec and SocioProphet/agentplane.",
  "type": "object",
  "required": [
    "kind",
    "specVersion",
    "runId",
    "taskId",
    "taskHash",
    "status",
    "sideEffects",
    "network",
    "modelCalls",
    "hostMutation",
    "eventStreamHash",
    "policyDecision",
    "modelRouteDecision",
    "memoryDecision",
    "approvalDecision",
    "replayClass",
    "emittedAt"
  ],
  "properties": {
    "kind": { "const": "AgentPlaneReasoningEvidence" },
    "specVersion": { "type": "string" },
    "runId": { "type": "string", "pattern": "^urn:srcos:reasoning-run:" },
    "taskId": { "type": "string" },
    "taskHash": { "type": "string" },
    "status": { "enum": ["completed", "failed", "blocked", "cancelled"] },
    "sideEffects": { "enum": ["none", "read-only", "guarded", "state-changing"] },
    "network": { "enum": ["none", "loopback-only", "guarded-egress", "outside-boundary"] },
    "modelCalls": { "enum": ["none", "local", "remote", "mixed"] },
    "hostMutation": { "enum": ["none", "guarded", "state-changing"] },
    "eventStreamHash": { "type": "string" },
    "policyDecision": { "type": "string" },
    "modelRouteDecision": { "type": "string" },
    "memoryDecision": { "type": "string" },
    "approvalDecision": { "type": "string" },
    "replayClass": { "enum": ["exact", "best-effort", "evidence-only", "non-replayable-side-effect"] },
    "emittedAt": { "type": "string" }
  },
  "additionalProperties": true
}
