{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.ai/superconscious/interpretability/artifact-source-lock.v0.json",
  "title": "Interpretability Artifact Source Lock v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lock_kind",
    "source_lock_id",
    "artifact_kind",
    "artifact_identity",
    "provider_binding_ref",
    "immutable_reference",
    "integrity",
    "access_boundary",
    "replay_class",
    "non_claims"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "lock_kind": { "const": "artifact-source-lock" },
    "source_lock_id": { "type": "string", "pattern": "^asl-[a-z0-9][a-z0-9._-]*$" },
    "artifact_kind": {
      "enum": [
        "model",
        "tokenizer",
        "sae",
        "transcoder",
        "probe",
        "dataset",
        "benchmark",
        "feature_registry_entry",
        "attribution_graph",
        "activation_cache",
        "manifold_baseline",
        "implementability_curve",
        "public_note"
      ]
    },
    "artifact_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "name"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "model_family": { "type": ["string", "null"] },
        "layer": { "type": ["integer", "null"], "minimum": 0 },
        "width": { "type": ["string", "null"] },
        "average_l0": { "type": ["string", "null"] },
        "feature_index": { "type": ["integer", "string", "null"] },
        "registry_url": { "type": ["string", "null"] }
      }
    },
    "provider_binding_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_binding_id", "access_mode"],
      "properties": {
        "provider_binding_id": { "type": "string", "pattern": "^pb-[a-z0-9][a-z0-9._-]*$" },
        "access_mode": { "enum": ["white_box", "gray_box", "black_box", "registry_only"] }
      }
    },
    "immutable_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source", "requested_ref", "resolved_ref"],
      "properties": {
        "source_type": { "enum": ["huggingface_repo", "github_repo", "neuronpedia_registry", "local_fixture", "provider_api", "artifact_store"] },
        "source": { "type": "string", "minLength": 1 },
        "requested_ref": { "type": ["string", "null"] },
        "resolved_ref": { "type": ["string", "null"] },
        "path": { "type": ["string", "null"] },
        "retrieved_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_sha256_status"],
      "properties": {
        "content_sha256_status": { "enum": ["available", "unavailable", "not_applicable", "synthetic_fixture"] },
        "content_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "metadata_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "size_bytes": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "access_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["download_required", "credentials_required", "egress_required", "license_or_terms_ref"],
      "properties": {
        "download_required": { "type": "boolean" },
        "credentials_required": { "type": "boolean" },
        "egress_required": { "type": "boolean" },
        "license_or_terms_ref": { "type": ["string", "null"] }
      }
    },
    "replay_class": { "enum": ["bit_exact", "manifest_only", "best_effort", "registry_reference", "non_replayable", "synthetic_fixture"] },
    "known_limitations": { "type": "array", "items": { "type": "string" } },
    "non_claims": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "allOf": [
    {
      "if": { "properties": { "artifact_kind": { "const": "sae" } }, "required": ["artifact_kind"] },
      "then": {
        "properties": {
          "artifact_identity": {
            "required": ["artifact_id", "name", "layer", "width", "average_l0"]
          },
          "provider_binding_ref": {
            "properties": { "access_mode": { "enum": ["white_box", "registry_only"] } }
          }
        }
      }
    },
    {
      "if": { "properties": { "artifact_kind": { "const": "feature_registry_entry" } }, "required": ["artifact_kind"] },
      "then": {
        "properties": {
          "provider_binding_ref": {
            "properties": { "access_mode": { "enum": ["registry_only", "white_box"] } }
          }
        }
      }
    }
  ]
}
