{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.ai/superconscious/m1/common-certificate-additions.v1.1.json",
  "title": "M1 v1.1 Common Certificate Additions",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "execution_status",
    "signing_authority",
    "counterfactuals_addressable"
  ],
  "properties": {
    "execution_status": { "$ref": "#/$defs/executionStatus" },
    "signing_authority": { "$ref": "#/$defs/signingAuthority" },
    "counterfactuals_addressable": { "$ref": "#/$defs/counterfactualsAddressable" },
    "battery_provenance": { "$ref": "#/$defs/batteryProvenance" },
    "authority_concentration_index": { "$ref": "#/$defs/authorityConcentrationIndex" }
  },
  "$defs": {
    "executionStatus": {
      "enum": ["doctrine_only", "synthetic_fixture", "runtime_partial", "runtime_executed", "failed"]
    },
    "signingAuthority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority_id", "authority_kind", "signed_at", "signing_method", "delegation_chain"],
      "properties": {
        "authority_id": { "type": "string" },
        "authority_kind": { "enum": ["individual", "automated_pipeline", "role", "delegated", "external_auditor"] },
        "signed_at": { "type": "string", "format": "date-time" },
        "signing_method": { "enum": ["sha256_content_hash", "gpg_signature", "sigstore", "x509", "internal_hmac"] },
        "delegation_chain": { "type": "array", "items": { "type": "string" } }
      }
    },
    "counterfactualsAddressable": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question_id", "question", "evidence_path", "answer_form", "answered_by_synthetic_fixture"],
        "properties": {
          "question_id": { "type": "string", "pattern": "^cf-[a-z0-9-]+$" },
          "question": { "type": "string" },
          "evidence_path": { "type": "string" },
          "answer_form": { "enum": ["boolean", "hash_match", "numerical_range", "categorical", "structured"] },
          "answered_by_synthetic_fixture": { "type": "boolean" }
        }
      }
    },
    "batteryProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constructed_at",
        "constructed_by",
        "construction_method",
        "source_corpus_refs",
        "prior_use_history",
        "compromised_for_adversarial_use",
        "held_out_status"
      ],
      "properties": {
        "constructed_at": { "type": "string", "format": "date-time" },
        "constructed_by": { "type": "string" },
        "construction_method": { "enum": ["manual_curation", "automated_generation", "external_dataset", "adversarial_mining"] },
        "source_corpus_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "content_sha256", "license"],
            "properties": {
              "name": { "type": "string" },
              "content_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "license": { "type": "string" }
            }
          }
        },
        "prior_use_history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["used_in_certificate_id", "used_at", "promotion_outcome"],
            "properties": {
              "used_in_certificate_id": { "type": "string" },
              "used_at": { "type": "string", "format": "date-time" },
              "promotion_outcome": { "type": "string" }
            }
          }
        },
        "compromised_for_adversarial_use": { "type": "boolean" },
        "held_out_status": { "enum": ["fresh", "rotated", "rotated_within_program", "compromised"] }
      }
    },
    "authorityConcentrationIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["distinct_authority_count", "fragment_authority_breakdown", "index_value", "interpretation", "weakness_flag"],
      "properties": {
        "distinct_authority_count": { "type": "integer", "minimum": 1 },
        "fragment_authority_breakdown": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "index_value": { "type": "number", "minimum": 0, "maximum": 1 },
        "interpretation": { "enum": ["single_authority", "partial_independence", "full_independence"] },
        "weakness_flag": { "type": "boolean" }
      }
    }
  }
}
