{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://superconscious.dev/schemas/m1/off-target-audit.v1.2.json","title":"M1D Off-Target Audit Certificate Fragment v1.2 Extension","description":"M1D v1.2 extension adding attribution_graph_refs. Full v1 structural fields remain governed by off-target-audit.v1.json.","type":"object","additionalProperties":true,"required":["schema_version","certificate_kind","attribution_graph_refs","non_claims"],"properties":{"schema_version":{"const":"1.2.0"},"certificate_kind":{"const":"m1d-off-target-audit"},"attribution_graph_refs":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["m1_5_certificate_id","m1_5_fragment_sha256","replay_state"],"properties":{"m1_5_certificate_id":{"type":"string"},"m1_5_fragment_sha256":{"$ref":"#/$defs/sha256"},"replay_state":{"type":"string","enum":["bit_exact_replay","manifest_matches_latent_diverges","manifest_diverges","not_yet_replayed"]}}}},"non_claims":{"type":"array","items":{"type":"string"}}},"$defs":{"sha256":{"type":"string","pattern":"^[a-f0-9]{64}$"}},"allOf":[{"if":{"properties":{"attribution_graph_refs":{"maxItems":0}}},"then":{"properties":{"non_claims":{"contains":{"const":"No edge-level attribution evidence; off-target audit is feature-aggregate only."}}}}}]}
